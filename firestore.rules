rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to check if user is a signed-in admin
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Helper to validate generic string ID characters
    function isValidId(id) {
      return id.size() > 0 && id.size() <= 128;
    }

    // Course collection rules
    match /courses/{courseId} {
      allow read: if true;
      allow write: if true;
    }

    // Certificate collection rules
    match /certificates/{certificateId} {
      allow read: if true;
      allow write: if true;
    }

    // Contact collection rules
    match /contacts/{contactId} {
      allow create: if true;
      allow read, update, delete: if true;
    }

    // Admin registry rules
    match /admins/{adminId} {
      allow read: if true;
      allow write: if true;
    }

    // Settings collection rules
    match /settings/{settingsId} {
      allow read, write: if true;
    }
  }
}
